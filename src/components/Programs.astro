---
import { siteConfig } from "../config";
const hasPrograms = siteConfig.programs && siteConfig.programs.length > 0;
---

{
  hasPrograms && (
    <section id="programs" class="p-8 sm:p-12 md:p-16 lg:p-24">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <h2 class="text-xl sm:text-2xl md:text-3xl lg:text-4xl font-bold text-white">
              Internships/Programs
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />
          </div>

          <div class="lg:col-span-8">
            <div class="space-y-6">
              {siteConfig.programs.map((item) => (
                <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-4 sm:p-5 md:p-6 hover:shadow-md transition-shadow duration-300">
                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between mb-3">
                    <div>
                      <h3 class="text-lg sm:text-xl font-semibold text-gray-900">
                        {item.title}
                      </h3>
                      <p
                        class="text-base sm:text-lg"
                        style={`color: ${siteConfig.accentColor}`}
                      >
                        {item.role}
                      </p>
                    </div>
                    <span class="text-xs sm:text-sm text-gray-500 mt-2 sm:mt-0">
                      {item.dateRange}
                    </span>
                  </div>
                  <p class="text-sm sm:text-base text-gray-600 whitespace-pre-line">
                    {item.description}
                  </p>
                  {item.link && (
                    <a
                      href={item.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="mt-3 inline-flex items-center text-sm font-semibold"
                      style={`color: ${siteConfig.accentColor}`}
                    >
                      View MindHaven Pitch Deck →
                    </a>
                  )}
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}
